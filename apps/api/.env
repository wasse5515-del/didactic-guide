# Database - REPLACE WITH YOUR SUPABASE DATABASE_URL
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/waag_db

# Clerk Authentication - GET FROM CLERK DASHBOARD
CLERK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_CLERK_SECRET
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_CLERK_PUBLISHABLE

# Anthropic API - GET FROM ANTHROPIC CONSOLE
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_KEY

# Upstash Redis - GET FROM UPSTASH CONSOLE
UPSTASH_REDIS_REST_URL=https://REPLACE_WITH_YOUR_UPSTASH_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_YOUR_UPSTASH_TOKEN

# Stripe (optional for now)
STRIPE_SECRET_KEY=sk_test_REPLACE_LATER

# ElevenLabs (optional for now)
ELEVENLABS_API_KEY=REPLACE_LATER

# API Configuration
API_PORT=3001
NODE_ENV=development
